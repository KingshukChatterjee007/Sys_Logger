# Backend Environment Variables

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
PORT=5000
HOST=0.0.0.0

# CORS Configuration (comma-separated origins, or * for all)
# For local development: http://localhost:3000,http://localhost:3001
# For production: https://sys-logger.vercel.app,https://sys-logger-git-main.vercel.app
CORS_ORIGINS=https://sys-logger.vercel.app,http://localhost:3000,http://localhost:3001


# Logging Configuration
# For Windows: C://Usage_Logs
# For Linux/Production: /tmp/usage_logs or /app/logs
LOG_FOLDER=/tmp/usage_logs
LOG_RETENTION_DAYS=2

# Logging Interval (seconds)
LOG_INTERVAL=4

# Redis Configuration (For Distributed Mode)
# REDIS_URL=redis://localhost:6379/0
# USE_REDIS=false

